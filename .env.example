# Jules Automation Tool - Environment Variables
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (required for idea generation)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token (required for repo creation)
# Create one at: https://github.com/settings/tokens
# Required scopes: repo
GITHUB_TOKEN=your_github_token_here

# Jules API Key (required for session creation)
# Get yours from the Jules console
JULES_API_KEY=your_jules_api_key_here
